# .gitignore — VillageTaste Resort Agent System

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment secrets ────────────────────────────────────────────────────────
.env
*.env.local

# ── RAG vector store (rebuilt by running rag/ingest.py) ─────────────────────
vector_store/
!vector_store/.gitkeep
assets

# ── HuggingFace model cache (large binary weights downloaded automatically) ───
.cache/
*.bin
*.safetensors

# ── Chroma temp / lock files ──────────────────────────────────────────────────
chroma.sqlite3

# ── IDE settings ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
